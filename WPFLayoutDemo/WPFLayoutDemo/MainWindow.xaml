        <Button x:Name="btnCanvasPanel" Content="CanvasPanelDemo" HorizontalAlignment="Left" VerticalAlignment="Top" Height="107" Width="284" Click="btnCanvasPanel_Click" Margin="31,190,0,0"/>
        <Button x:Name="btnDockPanel" Content="DockPanelDemo" HorizontalAlignment="Left" Margin="452,190,0,0" VerticalAlignment="Top" Height="107" Width="284" Click="btnDockPanel_Click"/>
        <Button x:Name="btnGridPanel" Content="GridPanelDemo" HorizontalAlignment="Left" Margin="243,317,0,0" VerticalAlignment="Top" Width="284" Height="107" Click="btnGridPanel_Click"/>

    </Grid>
</Window>
