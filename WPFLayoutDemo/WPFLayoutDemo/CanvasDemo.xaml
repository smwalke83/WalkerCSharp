<Window x:Class="WPFLayoutDemo.CanvasDemo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFLayoutDemo"
        mc:Ignorable="d"
        Title="CanvasDemo" Height="300" Width="300">
    <Canvas Background=" LightBlue">
        <Label Canvas.Top="34" Canvas.Left="10">Enter here:</Label>
        <TextBox Canvas.Top="38" Canvas.Left="110" Width="100"/>
        <Button Canvas.Top="70" Canvas.Left="130" Content="Click Me!" Padding="5"/>
    </Canvas>
</Window>
