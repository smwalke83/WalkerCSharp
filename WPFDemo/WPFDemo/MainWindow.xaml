<Window x:Class="WPFDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFDemo"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Label x:Name="lblFirstName" Content="First:" HorizontalAlignment="Left" Margin="109,78,0,0" VerticalAlignment="Top"/>
        <Label x:Name="lblLastName" Content="Last:" HorizontalAlignment="Left" Margin="109,99,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.574,1.488"/>
        <Label x:Name="lblStudentNumber" Content="Student Num:" HorizontalAlignment="Left" Margin="109,122,0,0" VerticalAlignment="Top"/>
        <Label x:Name="lblMajor" Content="Major:" HorizontalAlignment="Left" Margin="109,145,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.524,-2.571"/>
        <TextBox x:Name="txbFirstName" HorizontalAlignment="Left" Margin="234,80,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="278"/>
        <TextBox x:Name="txbLastName" HorizontalAlignment="Left" Margin="234,103,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="278"/>
        <TextBox x:Name="txbStudentNumber" HorizontalAlignment="Left" Margin="234,126,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="278"/>
        <TextBox x:Name="txbMajor" HorizontalAlignment="Left" Margin="234,149,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="278"/>
        <Button x:Name="btnSubmit" Content="Submit" HorizontalAlignment="Left" Margin="352,348,0,0" VerticalAlignment="Top" Click="btnSubmit_Click" Width="160"/>
        <TextBlock x:Name="txbResults" HorizontalAlignment="Left" Margin="57,352,0,0" TextWrapping="Wrap" VerticalAlignment="Top"/>
        <Label x:Name="lblScores" Content="Scores" HorizontalAlignment="Left" Margin="109,171,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.089,0.48"/>
        <ListBox x:Name="lbScores" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="234,180,288,136"/>
        <TextBox x:Name="txbScore" HorizontalAlignment="Left" Margin="341,326,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="66"/>
        <Button x:Name="btnAdd" Content="Add" HorizontalAlignment="Left" Margin="412,324,0,0" VerticalAlignment="Top" Width="100" Click="btnAdd_Click"/>
        <TextBox x:Name="txbTitle" HorizontalAlignment="Left" Margin="234,326,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="102"/>
        <Label x:Name="lblTitle" Content="Title" HorizontalAlignment="Left" Margin="234,303,0,0" VerticalAlignment="Top"/>
        <Label x:Name="lblScore" Content="Score" HorizontalAlignment="Left" Margin="341,303,0,0" VerticalAlignment="Top"/>

    </Grid>
</Window>
