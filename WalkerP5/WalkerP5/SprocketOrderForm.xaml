<Window x:Class="WalkerP5.SprocketOrderForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WalkerP5"
        mc:Ignorable="d"
        Title="Sprocket Order Form - Scott Walker" Height="450" Width="450">
    <Grid>
        <Label x:Name="lblTitle" Content="Super Sprocket Order Manager 3000" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top" Width="356" FontWeight="Bold" FontSize="20"/>
        <Label x:Name="lblCustomerName" Content="Customer Name" HorizontalAlignment="Left" Margin="10,52,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="txbCustomerName" HorizontalAlignment="Left" Margin="111,56,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="316"/>
        <CheckBox x:Name="cbLocalPickup" Content="Local Puickup?" HorizontalAlignment="Left" Margin="111,83,0,0" VerticalAlignment="Top" Checked="cbLocalPickup_Checked" Unchecked="cbLocalPickup_Unchecked"/>
        <TextBox x:Name="txbStreet" HorizontalAlignment="Left" Margin="111,103,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="316"/>
        <Label x:Name="lblStreet" Content="Street" HorizontalAlignment="Left" Margin="10,99,0,0" VerticalAlignment="Top"/>
        <Label x:Name="lblCity" Content="City" HorizontalAlignment="Left" Margin="111,126,0,0" VerticalAlignment="Top"/>
        <Label x:Name="lblState" Content="State" HorizontalAlignment="Left" Margin="248,126,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.301,0.425"/>
        <Label x:Name="lblZip" Content="Zip Code" HorizontalAlignment="Left" Margin="369,126,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.017,0.541"/>
        <TextBox x:Name="txbCity" HorizontalAlignment="Left" Margin="111,157,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="txbState" HorizontalAlignment="Left" Margin="248,157,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="103"/>
        <TextBox x:Name="txbZip" HorizontalAlignment="Left" Margin="369,157,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="60"/>
        <ListBox x:Name="lbItems" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="10,180,21,134"/>
        <Button x:Name="btnAdd" Content="Add" HorizontalAlignment="Left" Margin="10,308,0,0" VerticalAlignment="Top" Width="85" Click="btnAdd_Click"/>
        <Button x:Name="btnRemove" Content="Remove" HorizontalAlignment="Center" Margin="0,308,0,0" VerticalAlignment="Top" Width="86" Click="btnRemove_Click"/>
        <Button x:Name="btnUpdate" Content="Update" HorizontalAlignment="Left" Margin="344,308,0,0" VerticalAlignment="Top" Width="85" Click="btnUpdate_Click"/>

    </Grid>
</Window>
