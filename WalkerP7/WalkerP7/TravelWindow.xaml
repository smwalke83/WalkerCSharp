<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="WalkerP7.TravelWindow"
        Title="Scott Walker Program 7 - Text Based Adventure" SizeToContent="WidthAndHeight">
    <Grid>
        <TextBlock x:Name="txbLocationDescription" TextAlignment="Center" HorizontalAlignment="Center" Height="54" Margin="0,53,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top" Width="461" FontWeight="Bold"/>
        <ListBox x:Name="lbTraveOptions" HorizontalAlignment="Left" Height="93" Margin="34,359,0,0" VerticalAlignment="Top" Width="392" MouseDoubleClick="lbTraveOptions_MouseDoubleClick"/>
        <Label Content="Click on an option to travel in that direction:" HorizontalAlignment="Left" Margin="34,320,0,0" VerticalAlignment="Top" FontWeight="Bold"/>
        <Label Content="Location Description:" HorizontalAlignment="Center" Margin="0,22,0,0" VerticalAlignment="Top" FontWeight="Bold"/>

        <ListBox x:Name="lbLocationItems" Margin="34,210,467,281" Height="93"/>
        <Label Content="Select an item to search or take:" HorizontalAlignment="Left" Margin="34,157,0,0" VerticalAlignment="Top" Width="243" FontWeight="Bold"/>
        <TextBlock x:Name="txbGameStatus" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,120,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top" Height="Auto" Width="732" FontWeight="Bold"/>
        <Label x:Name="lblGameStatus" Content="Game Status:" HorizontalAlignment="Center" Margin="0,89,0,0" VerticalAlignment="Top" Width="84" FontWeight="Bold"/>
        <Button x:Name="btnSearch" Content="Search" HorizontalAlignment="Center" Margin="0,211,0,0" VerticalAlignment="Top" Width="52" Click="btnSearch_Click"/>
        <Button x:Name="btnTake" Content="Take --&gt;" HorizontalAlignment="Center" Margin="0,247,0,0" VerticalAlignment="Top" Width="52" Click="btnTake_Click"/>
        <Button x:Name="btnDrop" Content="&lt;-- Drop" HorizontalAlignment="Center" Margin="0,283,0,0" VerticalAlignment="Top" Click="btnDrop_Click" RenderTransformOrigin="0.423,5.164"/>
        <ListBox x:Name="lbInventory" Margin="468,211,34,132"/>
        <Label x:Name="lblInventory" Content="Inventory - Select Item to Drop:" HorizontalAlignment="Left" Margin="468,157,0,0" VerticalAlignment="Top" FontWeight="Bold"/>

    </Grid>
</Window>
